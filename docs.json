{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Arara Documentation",
  "openapi": "openapi.yaml",
  "colors": {
    "primary": "#FF6B35",
    "light": "#FF6B35",
    "dark": "#FF6B35"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Fustat"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Bem-vindo",
        "groups": [
          {
            "group": "Introducao",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Comece aqui",
        "groups": [
          {
            "group": "Configuracao Inicial",
            "pages": [
              "quickstart",
              "erros"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "versions": [
          {
            "version": "v2",
            "tag": "Latest",
            "default": true,
            "groups": [
              {
                "group": "Visão geral",
                "pages": [
                  "api-reference/introduction",
                  "api-reference/authentication"
                ]
              },
              {
                "group": "Endpoints",
                "pages": [
                  "api-reference/endpoint/v2/messages",
                  "api-reference/endpoint/v2/templates",
                  "api-reference/endpoint/v2/contacts",
                  "api-reference/endpoint/v2/campaigns",
                  "api-reference/endpoint/v2/api-keys",
                  "api-reference/endpoint/v2/flows"
                ]
              },
              {
                "group": "Regras de negócio",
                "pages": [
                  "business-rules/template-management",
                  "business-rules/usage-policies"
                ]
              }
            ]
          },
          {
            "version": "v1",
            "tag": "Legacy",
            "groups": [
              {
                "group": "Visão geral",
                "pages": [
                  "api-reference/introduction",
                  "api-reference/authentication"
                ]
              },
              {
                "group": "Endpoints",
                "pages": [
                  "api-reference/endpoint/messages",
                  "api-reference/endpoint/templates",
                  "api-reference/endpoint/campaigns",
                  "api-reference/endpoint/schedule",
                  "api-reference/endpoint/webhook",
                  "api-reference/endpoint/inbound"
                ]
              },
              {
                "group": "Regras de negócio",
                "pages": [
                  "business-rules/template-management",
                  "business-rules/usage-policies"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Oficiais",
            "pages": ["sdks"]
          }
        ]
      },
      {
        "tab": "Cookbooks",
        "groups": [
          {
            "group": "Receitas",
            "pages": [
              "cookbooks/auth-2fa",
              "cookbooks/marketing-smartlinks"
            ]
          }
        ]
      },
      {
        "tab": "Ecossistema",
        "groups": [
          {
            "group": "IA",
            "pages": ["ai-agents"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": ["changelog"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/ararahq/",
          "icon": "github"
        },
        {
          "anchor": "Landing Page",
          "href": "https://www.ararahq.com",
          "icon": "browser"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-black-transparente.png",
    "dark": "/logo/logo-white-transparente.png"
  },
  "navbar": {
    "links": [
      {
        "label": "llms.txt",
        "href": "https://docs.ararahq.com/llms.txt"
      },
      {
        "label": "Repositorio",
        "href": "https://github.com/ararahq"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://www.ararahq.com/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ararahq",
      "linkedin": "https://linkedin.com/company/ararahq"
    }
  }
}
