{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Arara — API de WhatsApp Business",
  "openapi": "openapi.yaml",
  "colors": {
    "primary": "#1c99a7",
    "light": "#5fbcc7",
    "dark": "#205f6a"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Geist"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Comece aqui",
        "groups": [
          {
            "group": "Início",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Conceitos WhatsApp",
            "pages": [
              "concepts/whatsapp",
              "concepts/templates",
              "concepts/24h-window",
              "concepts/number-quality",
              "concepts/pricing",
              "concepts/compliance",
              "templates/policy",
              "numbers"
            ]
          },
          {
            "group": "Migrar de",
            "pages": [
              "migrate/twilio",
              "migrate/z-api",
              "migrate/baileys",
              "migrate/take-blip"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "erros"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/v2/auth",
              "api-reference/endpoint/v2/messages",
              "api-reference/endpoint/v2/templates",
              "api-reference/endpoint/v2/contacts",
              "api-reference/endpoint/v2/campaigns",
              "api-reference/endpoint/v2/api-keys",
              "api-reference/endpoint/v2/flows"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks",
              "webhooks/events",
              "api-reference/events/partner-events"
            ]
          },
          {
            "group": "Regras de negócio",
            "pages": [
              "business-rules/planos-e-limites",
              "business-rules/template-management",
              "business-rules/usage-policies"
            ]
          }
        ]
      },
      {
        "tab": "SDKs e Ferramentas",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdks",
              "sdks/node",
              "sdks/python",
              "sdks/php",
              "sdks/java",
              "sdks/go",
              "sdks/ruby"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli"
            ]
          },
          {
            "group": "Agentes de IA",
            "pages": [
              "agents",
              "mcp-server",
              "mcp-tools"
            ]
          }
        ]
      },
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Receitas",
            "pages": [
              "recipes",
              "cookbooks/auth-2fa",
              "cookbooks/marketing-smartlinks",
              "recipes/abandoned-cart",
              "recipes/order-confirmation",
              "recipes/black-friday",
              "recipes/inbox-support",
              "recipes/multi-org"
            ]
          },
          {
            "group": "Integrações",
            "pages": [
              "integracoes",
              "integracoes/laravel",
              "integracoes/nextjs",
              "integracoes/shopify",
              "marketing"
            ]
          },
          {
            "group": "Smart Links",
            "pages": [
              "smart-links",
              "smart-links/attribution"
            ]
          },
          {
            "group": "Brain (IA)",
            "pages": [
              "brain",
              "actions",
              "brain/actions/abacate-pix",
              "brain/actions/cal-com",
              "brain/actions/catalog",
              "brain/actions/stripe"
            ]
          },
          {
            "group": "Recuperação",
            "pages": [
              "recovery"
            ]
          }
        ]
      },
      {
        "tab": "Sobre",
        "groups": [
          {
            "group": "Novidades",
            "pages": [
              "changelog",
              "roadmap"
            ]
          },
          {
            "group": "Operação",
            "pages": [
              "status",
              "contributing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/ararahq/",
          "icon": "github"
        },
        {
          "anchor": "Landing Page",
          "href": "https://ararahq.com",
          "icon": "browser"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/api",
      "destination": "/api-reference/introduction"
    },
    {
      "source": "/api-reference/api-tokens",
      "destination": "/api-reference/endpoint/v2/api-keys"
    },
    {
      "source": "/sdks/typescript",
      "destination": "/sdks/node"
    },
    {
      "source": "/ai-agents",
      "destination": "/mcp-server"
    },
    {
      "source": "/mcp",
      "destination": "/mcp-server"
    },
    {
      "source": "/api-reference/endpoint/messages",
      "destination": "/api-reference/endpoint/v2/messages"
    },
    {
      "source": "/api-reference/endpoint/templates",
      "destination": "/api-reference/endpoint/v2/templates"
    },
    {
      "source": "/api-reference/endpoint/campaigns",
      "destination": "/api-reference/endpoint/v2/campaigns"
    },
    {
      "source": "/api-reference/endpoint/inbound",
      "destination": "/webhooks/events"
    },
    {
      "source": "/api-reference/endpoint/schedule",
      "destination": "/api-reference/endpoint/v2/messages"
    },
    {
      "source": "/api-reference/endpoint/webhook",
      "destination": "/webhooks"
    },
    {
      "source": "/recipes/marketing",
      "destination": "/marketing"
    },
    {
      "source": "/concepts/webhooks",
      "destination": "/webhooks"
    }
  ],
  "logo": {
    "light": "/logo/arara-horizontal-light.svg",
    "dark": "/logo/arara-horizontal-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "llms.txt",
        "href": "https://docs.ararahq.com/llms.txt"
      },
      {
        "label": "Repositório",
        "href": "https://github.com/ararahq"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://ararahq.com/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ararahq",
      "linkedin": "https://linkedin.com/company/ararahq"
    }
  }
}
