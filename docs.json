{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Arara Documentation",
  "colors": {
    "primary": "#FF6B35",
    "light": "#FF6B35",
    "dark": "#FF6B35"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Fustat"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Bem-vindo",
        "groups": [
          {
            "group": "Introdução",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Comece aqui",
        "groups": [
          {
            "group": "Configuração Inicial",
            "pages": [
              "quickstart",
              "development",
              "erros"
            ]
          }
        ]
      },
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Conceitos",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Mensagens",
            "pages": [
              "api-reference/endpoint/messages"
            ]
          },
          {
            "group": "Campanhas e Agendamentos",
            "pages": [
              "api-reference/endpoint/campaigns",
              "api-reference/endpoint/schedule"
            ]
          },
          {
            "group": "Automação",
            "pages": [
              "api-reference/endpoint/templates",
              "api-reference/endpoint/webhook"
            ]
          },
          {
            "group": "Outros",
            "pages": [
              "api-reference/endpoint/inbound"
            ]
          },
          {
            "group": "Regras de Negócio",
            "pages": [
              "business-rules/template-management",
              "business-rules/usage-policies"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Oficiais",
            "pages": ["sdks"]
          }
        ]
      },
      {
        "tab": "Arquitetura",
        "groups": [
          {
            "group": "Internos",
            "pages": ["architecture/overview"]
          }
        ]
      },
      {
        "tab": "Cookbooks",
        "groups": [
          {
            "group": "Receitas",
            "pages": [
              "cookbooks/auth-2fa",
              "cookbooks/marketing-smartlinks"
            ]
          }
        ]
      },
      {
        "tab": "Ecossistema",
        "groups": [
          {
            "group": "IA",
            "pages": ["ai-agents"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": ["changelog"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/ararahq/",
          "icon": "github"
        },
        {
          "anchor": "Landing Page",
          "href": "https://www.ararahq.com",
          "icon": "browser"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-black-transparente.png",
    "dark": "/logo/logo-white-transparente.png"
  },
  "navbar": {
    "links": [
      {
        "label": "llms.txt",
        "href": "https://docs.ararahq.com/llms.txt"
      },
      {
        "label": "Repositório",
        "href": "https://github.com/ararahq"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://www.ararahq.com/dashboard"
    }
  },
  "announcement": {
    "title": "Usando a V2 da AraraHQ? Sua base URL e https://new-api.ararahq.com/api",
    "href": "/api-reference/introduction#base-url-v2"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ararahq",
      "linkedin": "https://linkedin.com/company/ararahq"
    }
  }
